}

/* =========================
   TITLE SYSTEM
========================= */

#motion-studio h2 {
  font-size: clamp(2rem, 4vw, 2.9rem);
  color: #2b2b33;
  margin-bottom: 10px;
  font-weight: 600;
  position: relative;
  z-index: 2;
  letter-spacing: 0.5px;
}

#motion-studio p {
  font-size: 1.1rem;
  color: #6a6a73;
  max-width: 680px;
  margin: 0 auto 45px auto;
  line-height: 1.7;
  position: relative;
  z-index: 2;
}

/* cinematic divider */
#motion-studio .divider {
  width: 85px;
  height: 3px;
