  background: linear-gradient(to right, transparent, #8b93a7, transparent);
  border-radius: 999px;
  position: relative;
  z-index: 2;
}

/* =========================
   FILTER BAR
========================= */

.motion-filters {
  margin-bottom: 35px;
  position: relative;
  z-index: 2;
}

.motion-btn {
  padding: 8px 16px;
  margin: 6px;
  border: none;
  border-radius: 999px;
  background: #ececec;
  color: #3a3a44;
  font-size: 0.9rem;
  cursor: pointer;
  transition: all 0.3s ease;
}

.motion-btn:hover {
  transform: translateY(-2px);
}

.motion-btn.active {
  background: #8b93a7;
  color: white;
}

/* =========================
   GRID (VIDEO / PROJECT CARDS)
========================= */

.motion-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(270px, 1fr));
  gap: 26px;
  max-width: 1150px;
  margin: 0 auto;
  position: relative;
  z-index: 2;
}

/* =========================
   MOTION CARD (CINEMATIC STYLE)
========================= */

.motion-card {
  background: rgba(255, 255, 255, 0.92);
  border-radius: 22px;
  overflow: hidden;
  box-shadow: 0 12px 35px rgba(0,0,0,0.08);
  backdrop-filter: blur(10px);
  position: relative;

  opacity: 0;
  transform: translateY(25px);
  transition: all 0.75s ease;
}

.motion-card.show {
  opacity: 1;
  transform: translateY(0);
}

/* Hover lift */
.motion-card:hover {
  transform: translateY(-10px);
  box-shadow: 0 22px 60px rgba(0,0,0,0.18);
}

/* =========================
   VIDEO / THUMBNAIL AREA
========================= */

.motion-card img {
  width: 100%;
  height: 190px;
  object-fit: cover;
  display: block;
  transition: transform 0.5s ease, filter 0.4s ease;
}

.motion-card:hover img {
  transform: scale(1.06);
  filter: brightness(0.9);
}

/* =========================
   PLAY OVERLAY
========================= */

.motion-card::after {
  content: "▶ Watch";
  position: absolute;
  inset: 0;
  background: rgba(40, 40, 55, 0.40);
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 1rem;
  letter-spacing: 1px;
  opacity: 0;
  transition: opacity 0.3s ease;
}

.motion-card:hover::after {
  opacity: 1;
}

/* =========================
   TEXT CONTENT
========================= */

.motion-card h3 {
  font-size: 1.05rem;
  margin-top: 12px;
  color: #2b2b33;
  font-weight: 600;
  padding: 0 16px;
}

.motion-card p {
  font-size: 0.9rem;
  color: #6a6a73;
  padding: 0 16px 16px 16px;
  line-height: 1.5;
}

/* =========================
   TAGS
========================= */

.motion-tag {
  display: inline-block;
  margin: 10px 16px 16px 16px;
  padding: 4px 10px;
  font-size: 0.75rem;
  background: #e7e9f0;
  color: #3f4250;
  border-radius: 999px;
}

/* =========================
   RESPONSIVE
========================= */

@media (max-width: 768px) {
  #motion-studio {
    padding: 85px 15px;
  }

  .motion-card img {
    height: 170px;
  }

  #motion-studio p {
    font-size: 1rem;
  }
}

@media (max-width: 480px) {
  .motion-grid {
    grid-template-columns: 1fr;
    gap: 18px;
  }

  .motion-card img {
    height: 190px;
  }
}
