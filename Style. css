========================= */

.contact-form {
  background: rgba(255, 255, 255, 0.92);
  padding: 25px;
  border-radius: 22px;
  box-shadow: 0 12px 35px rgba(0,0,0,0.08);
  backdrop-filter: blur(10px);
  text-align: left;
}

