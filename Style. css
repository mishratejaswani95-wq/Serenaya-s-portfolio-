.contact-form input:focus,
.contact-form textarea:focus {
  border-color: #b9a99a;
  box-shadow: 0 0 0 3px rgba(185,169,154,0.2);
}

/* textarea */
.contact-form textarea {
  min-height: 140px;
  resize: none;
}

