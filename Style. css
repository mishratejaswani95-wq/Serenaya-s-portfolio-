/* ==========================================
   ROOT
========================================== */

:root{

    --background:#F8F5EE;
    --paper:#FCF9F3;

    --peach:#F6D7C7;
    --peach-dark:#EDC5B1;

    --green:#869B72;
    --green-dark:#5F7350;

    --brown:#43362F;
    --brown-light:#6F5A4B;

    --shadow:0 12px 30px rgba(0,0,0,.08);

}

/* ==========================================
   RESET
========================================== */

*{

    margin:0;
    padding:0;
    box-sizing:border-box;

}

html{

    scroll-behavior:smooth;

}

body{

    background:var(--background);

    font-family:"Lora",serif;

    color:var(--brown);

    overflow-x:hidden;

    line-height:1.8;

}

/* Paper texture */

body::before{

    content:"";

    position:fixed;

    inset:0;

    background:url("images/paper-texture.png");

    opacity:.08;

    pointer-events:none;

    z-index:-1;

}

/* ==========================================
   TYPOGRAPHY
========================================== */

h1,h2,h3{

    font-family:"Cormorant Garamond",serif;

}

h1{

    font-size:5rem;

}

h2{

    font-size:3rem;

    margin-bottom:30px;

}

h3{

    font-size:1.8rem;

}

p{

    font-size:1.08rem;

}

/* ==========================================
   NAVBAR
========================================== */

.navbar{

    position:fixed;

    top:18px;

    left:50%;

    transform:translateX(-50%);

    width:92%;

    height:75px;

    background:rgba(246,215,199,.82);

    backdrop-filter:blur(12px);

    border-radius:30px;

    display:flex;

    justify-content:space-between;

    align-items:center;

    padding:0 40px;

    box-shadow:var(--shadow);

    z-index:999;

}

.logo{

    font-family:"Cormorant Garamond",serif;

    font-size:2rem;

    font-weight:700;

}

.navbar ul{

    display:flex;

    list-style:none;

    gap:28px;

}

.navbar a{

    text-decoration:none;

    color:var(--brown);

    font-weight:500;

    transition:.35s;

    display:flex;

    align-items:center;

    gap:7px;

}

.navbar a:hover{

    color:var(--green-dark);

    transform:translateY(-2px);

}

/* ==========================================
   HERO
========================================== */

.hero{

    min-height:100vh;

    display:flex;

    justify-content:space-between;

    align-items:center;

    padding:120px 10%;

}

.hero-text{

    width:52%;

    animation: nameAppear .9s ease;

}

.hero-text h3{

    color:var(--green);

}

.hero-text h2{

    margin-top:10px;

    font-size:2rem;

    color:var(--brown-light);

}

.hero-text p{

    margin-top:25px;

    max-width:650px;

}

.hero-image{

    width:38%;

    display:flex;

    justify-content:center;

}

.hero-image img{

    width:350px;

    height:350px;

    object-fit:cover;

    border-radius:50%;

    border:8px solid white;

    box-shadow:0 20px 40px rgba(0,0,0,.12);

}

/* ==========================================
   BUTTONS
========================================== */

.buttons{

    display:flex;

    gap:18px;

    margin-top:35px;

}

.btn{

    padding:15px 32px;

    background:var(--green);

    color:white;

    text-decoration:none;

    border-radius:40px;

    transition:.35s;

}

.btn:hover{

    background:var(--green-dark);

    transform:translateY(-4px);

}

.outline{

    background:none;

    color:var(--green-dark);

    border:2px solid var(--green);

}

.outline:hover{

    background:var(--green);

    color:white;

}

/* ==========================================
   CORNER FLOWERS
========================================== */

.corner{

    position:absolute;

    width:180px;

    opacity:.9;

}

.left{

    top:110px;

    left:20px;

}

.right{

    bottom:20px;

    right:20px;

    transform:rotateY(180deg);

}

/* ==========================================
   PAPER CARD
========================================== */

.paper{

    max-width:900px;

    margin:auto;

    padding:45px;

    background:var(--paper);

    border-radius:25px;

    box-shadow:var(--shadow);

}

/* ==========================================
   SECTIONS
========================================== */

section{

    padding:100px 10%;

}

section h2{

    text-align:center;

}

/* ==========================================
   SKILLS
========================================== */

.skill-grid{

    display:grid;

    grid-template-columns:repeat(auto-fit,minmax(220px,1fr));

    gap:35px;

}

.card{

    background:var(--paper);

    border-radius:25px;

    padding:35px;

    text-align:center;

    transition:.4s;

    box-shadow:var(--shadow);

}

.card:hover{

    transform:translateY(-10px);

}

.card img{

    width:90px;

    margin-bottom:20px;

} 
/*==========================================
    RESUME SECTION
==========================================*/

.timeline{

    max-width:1000px;

    margin:50px auto;

    display:flex;

    flex-direction:column;

    gap:35px;

}

.item{

    position:relative;

    background:var(--paper);

    padding:35px;

    border-radius:22px;

    box-shadow:var(--shadow);

    transition:.35s;

    overflow:hidden;

}

.item::before{

    content:"";

    position:absolute;

    left:0;

    top:0;

    width:8px;

    height:100%;

    background:var(--green);

}

.item:hover{

    transform:translateY(-8px);

}

.item h3{

    margin-bottom:15px;

}

/*==========================================
    ACHIEVEMENTS
==========================================*/

.achievement-grid{

    display:grid;

    grid-template-columns:repeat(auto-fit,minmax(260px,1fr));

    gap:30px;

    margin-top:50px;

}

.achievement-card{

    background:var(--paper);

    padding:40px;

    border-radius:25px;

    text-align:center;

    box-shadow:var(--shadow);

    transition:.35s;

}

.achievement-card:hover{

    transform:translateY(-10px) rotate(-1deg);

}

/*==========================================
    FOOTER
==========================================*/

footer{

    text-align:center;

    padding:70px 20px;

    margin-top:80px;

    background:rgba(246,215,199,.45);

}

footer p:first-child{

    font-family:"Cormorant Garamond",serif;

    font-size:2rem;

    margin-bottom:15px;

}

/*==========================================
    FADE ANIMATION
==========================================*/

.fade{

    opacity:0;

    transform:translateY(60px);

    transition:1s;

}

.fade.show{

    opacity:1;

    transform:translateY(0);

}

@keyframes fadeUp{

    from{

        opacity:0;
        transform:translateY(60px);

    }

    to{

        opacity:1;
        transform:translateY(0);

    }

}

/*==========================================
    FLOATING ANIMATION
==========================================*/

@keyframes floating{

    0%{

        transform:translateY(0);

    }

    50%{

        transform:translateY(-10px);

    }

    100%{

        transform:translateY(0);

    }

}

.hero-image img{

    animation:floating 5s ease-in-out infinite;

}

/*==========================================
    CUSTOM CURSOR
==========================================*/

.cursor{

    position:fixed;

    width:28px;

    height:28px;

    border-radius:50%;

    pointer-events:none;

    background:rgba(255,214,102,.25);

    border:2px solid rgba(255,214,102,.6);

    transform:translate(-50%,-50%);

    backdrop-filter:blur(4px);

    transition:

    width .2s,

    height .2s,

    background .2s;

    z-index:99999;

}

.cursor.active{

    width:55px;

    height:55px;

    background:rgba(255,214,102,.18);

}

/*==========================================
    SCROLLBAR
==========================================*/

::-webkit-scrollbar{

    width:12px;

}

::-webkit-scrollbar-track{

    background:var(--background);

}

::-webkit-scrollbar-thumb{

    background:var(--green);

    border-radius:30px;

}

::-webkit-scrollbar-thumb:hover{

    background:var(--green-dark);

}

/*==========================================
    SELECTION
==========================================*/

::selection{

    background:var(--peach);

    color:var(--brown);

}

/*==========================================
    LINKS
==========================================*/

a{

    transition:.3s;

}

img{

    user-select:none;

}

/*==========================================
    RESPONSIVE
==========================================*/

@media(max-width:1000px){

.hero{

    flex-direction:column-reverse;

    text-align:center;

    gap:60px;

}

.hero-text{

    width:100%;

}

.hero-image{

    width:100%;

}

.hero-image img{

    width:270px;

    height:270px;

}

.navbar{

    flex-direction:column;

    height:auto;

    padding:20px;

}

.navbar ul{

    flex-wrap:wrap;

    justify-content:center;

    margin-top:15px;

    gap:18px;

}

.buttons{

    justify-content:center;

}

}

@media(max-width:700px){

h1{

    font-size:3rem;

}

h2{

    font-size:2.2rem;

}

.hero{

    padding-top:180px;

}

.card{

    padding:25px;

}

.paper{

    padding:30px;

}

.corner{

    width:120px;

}

} 
body{
    opacity:0;
    transition:opacity .4s ease;
}

body.loaded{
    opacity:1;
}

.navbar.scrolled{
    box-shadow:0 20px 45px rgba(0,0,0,.15);
}

.btn{
    position:relative;
    overflow:hidden;
}

.ripple{
    ...
}

@keyframes ripple{
    ...
}

@keyframes nameAppear{
    ...
} 
